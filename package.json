{
  "name": "grype",
  "displayName": "Grype",
  "description": "Unofficial grype & syft integration for Podman Desktop",
  "version": "0.1.0-next",
  "icon": "icon.png",
  "publisher": "podman-desktop",
  "private": true,
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.2.3"
  },
  "scripts": {
    "build": "cd packages/backend && npm run build",
    "format:check": "prettier --check \"packages/**/*.{ts,js,json,svelte}\"",
    "format:fix": "prettier --write \"packages/**/*.{ts,js,json,svelte}\"",
    "lint:check": "eslint . --cache",
    "lint:fix": "eslint . --cache --fix",
    "typecheck:configs": "tsc --noEmit --project ./tsconfig.json",
    "typecheck": "pnpm run typecheck:configs && pnpm run --recursive --parallel typecheck",
    "test:unit": "pnpm run --recursive --parallel test:unit"
  },
  "resolutions": {
    "string-width": "^4.2.0",
    "wrap-ansi": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^9.39.3",
    "@podman-desktop/api": "^1.25.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/eslint-plugin": "^1.6.9",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.2",
    "eslint-import-resolver-custom-alias": "^1.3.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-etc": "^2.0.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-null": "^1.0.2",
    "eslint-plugin-redundant-undefined": "^1.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^3.0.6",
    "eslint-plugin-svelte": "^3.15.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0",
    "svelte-eslint-parser": "^1.5.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.16"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "tests/*"
    ]
  },
  "packageManager": "pnpm@10.15.0+sha512.486ebc259d3e999a4e8691ce03b5cac4a71cbeca39372a9b762cb500cfdf0873e2cb16abe3d951b1ee2cf012503f027b98b6584e4df22524e0c7450d9ec7aa7b"
}
