{
  "name": "grype",
  "displayName": "Grype",
  "description": "Unofficial grype & syft integration for Podman Desktop",
  "version": "0.2.0-next",
  "icon": "icon.png",
  "publisher": "podman-desktop",
  "private": true,
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.2.3"
  },
  "scripts": {
    "build:api": "cd packages/api && npm run build",
    "build:backend": "cd packages/backend && npm run build",
    "build": "pnpm run build:api && pnpm run build:backend",
    "format:check": "prettier --check \"packages/**/*.{ts,js,json,svelte}\"",
    "format:fix": "prettier --write \"packages/**/*.{ts,js,json,svelte}\"",
    "lint:check": "eslint . --cache",
    "lint:fix": "eslint . --cache --fix",
    "typecheck:configs": "tsc --noEmit --project tsconfig.vite.json",
    "typecheck": "pnpm run typecheck:configs && pnpm run --recursive --parallel typecheck",
    "test:unit": "vitest --run"
  },
  "resolutions": {
    "string-width": "^4.2.0",
    "wrap-ansi": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@podman-desktop/api": "^1.26.2",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/eslint-plugin": "^1.6.16",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-import-resolver-custom-alias": "^1.3.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-etc": "^2.0.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-null": "^1.0.2",
    "eslint-plugin-redundant-undefined": "^1.0.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-svelte": "^3.17.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.0",
    "svelte-eslint-parser": "^1.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "tests/*"
    ]
  },
  "pnpm": {
    "overrides": {
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "flatted@<3.4.0": ">=3.4.0",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
      "brace-expansion@<1.1.13": "1.1.13",
      "postcss@<8.5.12": "^8.5.12"
    }
  },
  "packageManager": "pnpm@10.15.0+sha512.486ebc259d3e999a4e8691ce03b5cac4a71cbeca39372a9b762cb500cfdf0873e2cb16abe3d951b1ee2cf012503f027b98b6584e4df22524e0c7450d9ec7aa7b"
}
