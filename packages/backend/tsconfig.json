{
  "extends": "../../tsconfig.node.json",
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "/@/*": ["./src/*"],
      "/@generated/*": ["./generated/*"]
    }
  },
  "include": ["src", "types/*.d.ts", "../../types/*.d.ts"],
  "exclude": ["vite.config.ts", "vitest.config.ts", "vite-plugins/**/*.ts"]
}
