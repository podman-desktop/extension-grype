{
  "name": "grype",
  "displayName": "Grype",
  "description": "Unofficial grype & syft integration for Podman Desktop",
  "version": "0.2.0-next",
  "icon": "icon.png",
  "publisher": "podman-desktop",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "podman-desktop": ">=1.25.0"
  },
  "main": "./dist/extension.cjs",
  "scripts": {
    "build": "vite build",
    "test:unit": "vitest run --coverage",
    "test:watch": "vitest watch --coverage",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "watch": "vite --mode development build -w",
    "typecheck": "tsc --noEmit"
  },
  "contributes": {
    "commands": [
      {
        "command": "grype:clear-cache",
        "title": "Grype: clear cache"
      }
    ]
  },
  "devDependencies": {
    "@podman-desktop/api": "^1.27.2",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^24",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "semver": "^7.8.1",
    "json-schema-to-typescript": "^15.0.4"
  },
  "dependencies": {
    "@podman-desktop/grype-extension-api": "workspace:^",
    "@octokit/rest": "^22.0.1",
    "adm-zip": "^0.5.17",
    "tar": "^7.5.15",
    "inversify": "^8.1.0",
    "zod": "^4.4.3"
  }
}
